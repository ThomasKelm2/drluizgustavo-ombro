// src/Components/TreatmentsSection.astro
---

<section id="treatments" class="treatments-section">
  <!-- TREATMENTS_SECTION_PRESENT -->
  <div class="container">
    
    <div class="header-text">
      <span class="eyebrow">EXISTE SAÍDA</span>
      <h2 class="title">Tratamento personalizado para cada caso</h2>
      <p class="subtitle">Não existe receita única. O melhor caminho depende do seu diagnóstico, histórico e objetivos de vida.</p>
    </div>

    <div class="cards-wrapper">
      
      <div class="treatment-card light-card">
        <span class="card-eyebrow green-text">ABORDAGEM CLÍNICA</span>
        <h3 class="card-title">Tratamentos sem cirurgia</h3>
        
        <ul class="treatment-list light-list">
          <li>
            <span class="dot"></span>
            <p><strong>Medicação Orientada</strong>: Anti-inflamatórios e corticoides no momento e dose certos</p>
          </li>
          <li>
            <span class="dot"></span>
            <p><strong>Infiltração Guiada</strong>: Corticoide ou ácido hialurônico com aplicação precisa na articulação</p>
          </li>
          <li>
            <span class="dot"></span>
            <p><strong>Fisioterapia Direcionada</strong>: Protocolo específico para o seu diagnóstico</p>
          </li>
          <li>
            <span class="dot"></span>
            <p><strong>PRP (Plasma Rico em Plaquetas)</strong>: Terapia regenerativa para casos selecionados</p>
          </li>
          <li>
            <span class="dot"></span>
            <p><strong>Reabilitação e Prevenção</strong>: Retorno seguro às atividades físicas e do dia a dia</p>
          </li>
        </ul>
      </div>

      <div class="treatment-card dark-card">
        <span class="card-eyebrow yellow-text">QUANDO NECESSÁRIO</span>
        <h3 class="card-title text-white">Tratamento Cirúrgico</h3>
        
        <ul class="treatment-list dark-list">
          <li>
            <span class="dot dark-dot"></span>
            <p><strong>Artroscopia do Ombro</strong>: Minimamente invasiva, pequenas incisões e recuperação mais rápida</p>
          </li>
          <li>
            <span class="dot dark-dot"></span>
            <p><strong>Reparo do Manguito Rotador</strong>: Reconstituição dos tendões com alta taxa de sucesso</p>
          </li>
          <li>
            <span class="dot dark-dot"></span>
            <p><strong>Estabilização do Ombro</strong>: Para luxação recorrente e instabilidade crônica</p>
          </li>
          <li>
            <span class="dot dark-dot"></span>
            <p><strong>Prótese Total do Ombro</strong>: Para casos avançados de artrose com dor intensa</p>
          </li>
        </ul>

        <div class="info-box">
          <p><strong>Antes de qualquer decisão:</strong> a maioria dos casos é resolvida sem cirurgia. Quando ela é indicada, as técnicas modernas proporcionam recuperação muito mais rápida e resultados duradouros.</p>
        </div>
      </div>

    </div>

    <div class="cta-section">
      <div class="cta-texts">
        <p class="cta-text">Saiba qual o</p>
        <p class="cta-text-bold">tratamento ideal para você</p>
      </div>
      <a href="https://wa.me/5541999782006?text=Ol%C3%A1!%20Gostaria%20de%20marcar%20uma%20consulta%20com%20o%20Dr.%20Luiz%20com%20rela%C3%A7%C3%A3o%20a%20meu%20ombro" target="_blank" rel="noopener noreferrer" class="cta-button-yellow">
        <svg class="whatsapp-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" aria-hidden="true" focusable="false">
          <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157.1zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
        </svg>
        QUERO AGENDAR UMA CONSULTA
      </a>
    </div>

  </div>
</section>

<style>
  .treatments-section {
    background-color: #f5f8f6; /* Fundo bem clarinho off-white/green */
    padding: 6rem 1rem;
    text-align: center;
  }

  .container {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
  }

  /* Cabeçalho da Seção */
  .header-text {
    margin-bottom: 4rem;
  }

  .eyebrow {
    color: #428482;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: block;
    margin-bottom: 1rem;
  }

  .title {
    color: #1a3b3b;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .subtitle {
    color: #666666;
    font-size: 0.85rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    font-style: italic;
  }

  /* Wrapper dos Cartões */
  .cards-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: stretch;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Estilos Base dos Cartões */
  .treatment-card {
    border-radius: 16px;
    padding: 3rem 2.5rem;
    text-align: left;
    display: flex;
    flex-direction: column;
  }

  .card-eyebrow {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .green-text { color: #428482; }
  .yellow-text { color: #f69f46; }

  .card-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0 0 2rem 0;
  }

  .text-white { color: #ffffff; }
  
  /* Cartão Claro */
  .light-card {
    background-color: #ffffff;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.05);
  }

  .light-card .card-title {
    color: #1a3b3b;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.05);
  }

  /* Cartão Escuro */
  .dark-card {
    background-color: #163634;
    box-shadow: 0 15px 40px rgba(22, 54, 52, 0.2);
  }

  /* Listas */
  .treatment-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .treatment-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.85rem 0;
  }

  /* Linhas separadoras (não aplica no último item) */
  .light-list li:not(:last-child) { border-bottom: 1px solid #eef2f0; }
  .dark-list li:not(:last-child) { border-bottom: 1px solid #234e4a; }

  .treatment-list p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .light-list p { color: #555555; }
  .light-list strong { color: #1a3b3b; font-weight: 700; }

  .dark-list p { color: #aebec2; }
  .dark-list strong { color: #ffffff; font-weight: 700; }

  /* Dots */
  .dot {
    min-width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #3b8c6e;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .dark-dot {
    background-color: #4cb890;
  }

  /* Caixa de Informação (Footer do Cartão Escuro) */
  .info-box {
    background-color: rgba(66, 132, 130, 0.15); /* Fundo verde translúcido */
    border: 1px solid #3b6b68;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
  }

  .info-box p {
    color: #dce4d3;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .info-box strong {
    color: #f69f46; /* Texto amarelo/laranja em destaque */
  }

  /* CTA Section */
  .cta-section {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-texts {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .cta-text {
    color: #1a3b3b;
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
  }

  .cta-text-bold {
    color: #1a3b3b;
    font-size: 1.4rem;
    font-weight: 900;
    margin: 0 0 0rem 0;
  }

  .cta-button-yellow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(90deg, #f69f46 0%, #f8b366 50%, #f69f46 100%);
    background-size: 200% 100%;
    background-position: 0% 50%;
    color: #ffffff;
    text-decoration: none;
    padding: 0.8rem 2.0rem;
    border-radius: 25px;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(246, 159, 70, 0.3);
    transition: background-position 0.7s ease, transform 0.2s ease;
    min-width: 360px;
    justify-content: center;
  }

  .cta-button-yellow:hover {
    background-position: 100% 50%;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(246, 159, 70, 0.4);
  }

  .cta-button-yellow:focus-visible {
    outline: 3px solid #f69f46;
    outline-offset: 3px;
  }

  .whatsapp-icon {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* Responsividade */
  @media (max-width: 992px) {
    .cards-wrapper {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .treatments-section {
      padding: 4rem 1rem;
    }
    .treatment-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
