---
// src/Components/FaqSection.astro

const faqs = [
  {
    question: '"E se precisar de cirurgia?"',
    answer: {
      beforeHighlight: 'É um medo compreensível e por isso a primeira consulta existe: para ',
      highlight: 'entender o seu caso com calma',
      afterHighlight: '. A maioria dos pacientes é tratada sem cirurgia. Quando ela é indicada, as técnicas de artroscopia são minimamente invasivas, com pequenas incisões e recuperação significativamente mais rápida do que as cirurgias tradicionais.'
    }
  },
  {
    question: '"Quanto tempo dura a recuperação?"',
    answer: {
      beforeHighlight: 'Depende do tratamento. Em casos clínicos, muitos pacientes sentem melhora em poucas semanas. Nas cirurgias artroscópicas, a maioria retorna às atividades leves em 4 a 6 semanas. ',
      highlight: 'Você terá um protocolo de reabilitação detalhado do início ao fim',
      afterHighlight: ', nunca ficará no escuro.'
    }
  },
  {
    question: '"Quanto custa a consulta particular?"',
    answer: {
      beforeHighlight: 'A consulta particular garante diagnóstico preciso e atenção total ao seu caso. Entre em contato pelo WhatsApp para conhecer os ',
      highlight: 'valores e condições de pagamento',
      afterHighlight: '. O investimento em uma boa avaliação pode te poupar anos de dor e tratamentos ineficazes.'
    }
  }
];
---

<section id="faqsection" class="faq-section">
  <!-- FAQ_SECTION_PRESENT -->
  <div class="container">
    
    <div class="header-text">
      <span class="eyebrow">SUAS DÚVIDAS RESPONDIDAS</span>
      <h2 class="title">Eu entendo os seus problemas</h2>
      <p class="subtitle">Antes de decidir consultar, é completamente natural ter dúvidas. Aqui estão as mais comuns, respondidas com honestidade.</p>
    </div>

    <div class="faq-grid">
      {faqs.map((faq) => (
        <div class="faq-card">
          <div class="card-header">
            <div class="icon-box">?</div>
            <h3 class="card-title">{faq.question}</h3>
          </div>
          <p class="card-answer">
            {faq.answer.beforeHighlight}
            <strong class="text-white">{faq.answer.highlight}</strong>
            {faq.answer.afterHighlight}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .faq-section {
    /* Cor exata do manual de marca: R=25 G=60 B=64 */
    background-color: #193c40; 
    padding: 5rem 1rem;
    text-align: center;
    color: #ffffff;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  /* Cabeçalho da Seção */
  .header-text {
    margin-bottom: 4rem;
  }

  .eyebrow {
    color: #6db5b2; /* Um tom mais claro do fundo para dar contraste */
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: block;
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .subtitle {
    color: #b9cfce;
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Grid dos Cartões */
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Estilo dos Cartões (adaptado para fundo escuro) */
  .faq-card {
    background-color: rgba(255, 255, 255, 0.03); /* Fundo levemente translúcido */
    border: 1px solid rgba(255, 255, 255, 0.1); /* Borda sutil */
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .faq-card:hover {
    transform: translateY(-5px);
    background-color: rgba(255, 255, 255, 0.06);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .icon-box {
    color: #f69f46; /* Amarelo/Laranja para o ponto de interrogação */
    font-size: 1.2rem;
    font-weight: 800;
    background-color: rgba(246, 159, 70, 0.1);
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 800;
    margin: 0;
    line-height: 1.4;
    color: #ffffff;
  }

  .card-answer {
    color: #aebec2; /* Cinza/verde clarinho para o texto de apoio */
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .card-answer .text-white {
    color: #ffffff;
    font-weight: 700;
  }

  /* Responsividade */
  @media (max-width: 992px) {
    .faq-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: 2rem 1rem;
    }
    .faq-grid {
      grid-template-columns: 1fr;
    }
    .faq-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
